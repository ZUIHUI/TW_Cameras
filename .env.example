TDX_CLIENT_ID=your-tdx-client-id
TDX_CLIENT_SECRET=your-tdx-client-secret
# Optional. Default keeps Vercel first load stable; use "all" or comma-separated city codes later.
TDX_CITY_CODES=Taipei
CWA_API_KEY=your-cwa-api-key
MOENV_API_KEY=your-moenv-api-key
# Optional. The first WRA source used by this prototype is public at the time of implementation.
# WRA_API_KEY=your-wra-api-key
API_PORT=8787
VITE_API_BASE_URL=/api
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
